# E2E Test environment variables
# Copy this file to .env and fill in your values.
# The test suite reads from the same .env as the backend,
# plus these additional vars:

# URL where backend is running (local or staging)
API_BASE_URL=http://127.0.0.1:8000

# Supabase credentials (same as in .env usually)
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_KEY=your-anon-key

# Dedicated test user (create this user in Supabase Auth)
SUPABASE_TEST_EMAIL=pk@gmail.com
SUPABASE_TEST_PASSWORD=123
